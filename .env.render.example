# Render web service environment variables.
# Do not commit real passwords. Put real values in Render Dashboard -> Environment.

# Use Render's Internal Database URL if the API is also deployed on Render.
# The app accepts both postgresql:// and postgresql+psycopg://.
DATABASE_URL=postgresql://USER:PASSWORD@INTERNAL_RENDER_DB_HOST:5432/DB_NAME

SEED_DATA_PATH=data/seed_data_logistics.json
AUTO_SEED=true
LOG_LEVEL=INFO

# Render is fine for FastAPI + Postgres. Do not run Ollama in the same Render web service.
LLM_PROVIDER=ollama
ENABLE_LLM_EXPLANATIONS=false
ENABLE_LLM_CARRIER_NORMALIZATION=false

# If you host Ollama separately, set these and enable the two flags above.
# OLLAMA_BASE_URL=http://YOUR_OLLAMA_HOST:11434
# OLLAMA_MODEL=qwen3:8b
