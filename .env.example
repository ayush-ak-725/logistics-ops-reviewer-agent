DATABASE_URL=postgresql+psycopg://freight:freight@localhost:5432/freight
SEED_DATA_PATH=data/seed_data_logistics.json
AUTO_SEED=true
LOG_LEVEL=INFO
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=60
# Optional; enables LLM-polished explanations. Deterministic explanations are the default.
ENABLE_LLM_EXPLANATIONS=false
# Optional; asks the LLM to resolve messy carrier names only when exact/fuzzy matching is inconclusive.
ENABLE_LLM_CARRIER_NORMALIZATION=false
# Optional if you switch LLM_PROVIDER=openai.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
